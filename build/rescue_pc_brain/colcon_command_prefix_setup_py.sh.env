AMENT_PREFIX_PATH=/workspace/install/rescue_robot_description:/workspace/install/ldlidar:/workspace/install/ldlidar_node:/workspace/install/ldlidar_component:/opt/ros/jazzy
CMAKE_PREFIX_PATH=/workspace/install/ldlidar:/workspace/install/ldlidar_node:/workspace/install/ldlidar_component:/opt/ros/jazzy/opt/gz_math_vendor:/opt/ros/jazzy/opt/gz_utils_vendor:/opt/ros/jazzy/opt/gz_cmake_vendor
COLCON=1
COLCON_PREFIX_PATH=/workspace/install
DEBIAN_FRONTEND=noninteractive
HOME=/root
HOSTNAME=fedora
LANG=C.UTF-8
LC_ALL=C.UTF-8
LD_LIBRARY_PATH=/workspace/install/ldlidar_component/lib:/opt/ros/jazzy/opt/rviz_ogre_vendor/lib:/opt/ros/jazzy/lib/x86_64-linux-gnu:/opt/ros/jazzy/opt/gz_math_vendor/lib:/opt/ros/jazzy/opt/gz_utils_vendor/lib:/opt/ros/jazzy/opt/gz_cmake_vendor/lib:/opt/ros/jazzy/lib
OLDPWD=/workspace
PATH=/opt/ros/jazzy/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
PWD=/workspace/build/rescue_pc_brain
PYTHONPATH=/workspace/build/rescue_robot_description:/workspace/install/rescue_robot_description/lib/python3.12/site-packages:/opt/ros/jazzy/lib/python3.12/site-packages
ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET
ROS_DISTRO=jazzy
ROS_PYTHON_VERSION=3
ROS_VERSION=2
SHLVL=1
_=/usr/bin/colcon
container=podman
